# Postgres (Supabase) — crear proyecto gratis en https://supabase.com
# URL_BASE_DATOS: connection string "Transaction pooler" (puerto 6543), usada por la app.
# URL_DIRECTA: connection string "Direct connection" (puerto 5432), usada solo por prisma migrate/db push.
# Ambas están en Project Settings → Database → Connection string, en tu dashboard de Supabase.
URL_BASE_DATOS="postgresql://postgres.xxxxxxxxxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
URL_DIRECTA="postgresql://postgres.xxxxxxxxxxxx:password@aws-0-region.pooler.supabase.com:5432/postgres"

# Puerto del servidor
PUERTO=4000
NODE_ENV=development

# JWT
SECRETO_TOKEN_ACCESO="change-me-access-secret"
SECRETO_TOKEN_REFRESCO="change-me-refresh-secret"

# CORS — origen del frontend en desarrollo
ORIGEN_CORS="http://localhost:5173"

# Redis (Upstash) — se completa en la Fase 4
URL_REST_UPSTASH_REDIS=""
TOKEN_REST_UPSTASH_REDIS=""

# MongoDB (Atlas) — se completa en la Fase 4
URI_MONGODB=""
